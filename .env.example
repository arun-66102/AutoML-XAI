# AutoML_XAI environment configuration

# LLM provider options:
# heuristic = no external LLM, uses local deterministic rules
# groq = Groq API
# ollama = local Ollama server
ENGINEEREDX_LLM_PROVIDER=heuristic

# Groq configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama configuration
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1

# FastAPI local runtime
APP_HOST=127.0.0.1
APP_PORT=8000

